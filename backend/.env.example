# Backend Environment Variables
# Copy this file to .env and fill in your values — never commit .env itself.

# PostgreSQL connection string
DATABASE_URL="postgresql://USER:PASSWORD@localhost:5432/lotwise?schema=public"

# Secret used to sign JWT tokens — use a long random string in production
JWT_SECRET="change_me_to_a_long_random_secret"

# Token expiry (e.g. "7d", "24h", "3600")
JWT_EXPIRES_IN="7d"

# Port the Express server listens on
PORT=3000

# Frontend origin allowed by CORS — matches Vite's default dev port
FRONTEND_ORIGIN="http://localhost:5173"
